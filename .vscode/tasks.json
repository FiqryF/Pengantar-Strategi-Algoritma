{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build active C++ file with FreeGLUT",
      "type": "shell",
      "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
      "args": [
        "${file}",
        "-o",
        "${fileDirname}\\${fileBasenameNoExtension}.exe",
        "-lfreeglut",
        "-lopengl32",
        "-lglu32"
      ],
      "options": {
        "cwd": "${fileDirname}",
        "env": {
          "Path": "C:\\msys64\\ucrt64\\bin;C:\\msys64\\usr\\bin;${env:Path}"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}
